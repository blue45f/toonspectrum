#!/usr/bin/env sh
set -e

# pnpm 이 PATH 에 없을 때(GUI git 클라이언트·비로그인 셸·일부 CI) 자체적으로 PATH 를 보강한다.
# husky 의 머신-로컬 ~/.config/husky/init.sh 가 이미 처리했다면 이 블록은 사실상 no-op 이다.
if ! command -v pnpm >/dev/null 2>&1; then
  # nvm 으로 설치한 node 버전들의 bin (정렬상 마지막=최신이 우선)
  if [ -d "$HOME/.nvm/versions/node" ]; then
    for _d in $(ls -d "$HOME/.nvm/versions/node"/*/bin 2>/dev/null | sort -V); do
      PATH="$_d:$PATH"
    done
  fi
  # corepack/pnpm 의 일반 설치 경로
  PATH="$HOME/Library/pnpm:$HOME/.local/share/pnpm:/opt/homebrew/bin:/usr/local/bin:$PATH"
  export PATH
  # 그래도 없으면 corepack 으로 활성화 시도(corepack 은 node 와 함께 배포됨)
  if ! command -v pnpm >/dev/null 2>&1 && command -v corepack >/dev/null 2>&1; then
    corepack enable pnpm >/dev/null 2>&1 || true
  fi
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-push: pnpm 을 찾지 못했습니다. corepack(또는 nvm)으로 pnpm 을 설치하거나," >&2
  echo "          GUI 클라이언트라면 ~/.config/husky/init.sh 에 PATH 를 설정하세요." >&2
  echo "          (검증을 건너뛰고 강제로 푸시하려면: git push --no-verify)" >&2
  exit 127
fi

pnpm run verify:push
