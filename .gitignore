# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# production
/build
/dist
/apps/api/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# IDE
/.idea/

# dev/QA artifacts (browser automation, screenshots)
/.playwright-mcp/
/*.png

# local database (libSQL/SQLite)
/data/
*.db
*.db-journal
*.db-wal
*.db-shm

!.env.example
