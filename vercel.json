{
  "framework": null,
  "buildCommand": "pnpm --filter @webtoon-nest/api build && pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "apps/api/dist/**"
    },
    "api/og.js": {
      "maxDuration": 30,
      "includeFiles": "dist/index.html"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/title/([^/]+)", "dest": "/api/og?slug=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
