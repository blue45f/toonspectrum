# ── Auth.js ──
# 필수: openssl rand -base64 32  로 생성
AUTH_SECRET=

# ── 소셜 로그인 (선택) ──
# 카카오: https://developers.kakao.com 앱 생성 → REST API 키 / redirect: /api/auth/callback/kakao
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
# 구글: https://console.cloud.google.com → OAuth 클라이언트 / redirect: /api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── DB (선택) ──
# 미설정 시 로컬 file:./data/webdex.db 사용. 프로덕션은 Turso/libSQL.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── 실시간 라이브 랭킹 설정 ──
# 단위: 초. 값이 작을수록 라이브 반영이 빨라지나 외부 요청이 늘어납니다.
# fixed: 고정 간격 갱신, adaptive: 요청량에 따라 간격을 변동(요청 집중 시 짧게, 평시엔 완만하게), off: 스케줄러 미사용
WEBTOON_LIVE_REFRESH_MODE=fixed
WEBTOON_LIVE_TTL_SECONDS=120
WEBTOON_LIVE_REFRESH_INTERVAL_SECONDS=120
WEBTOON_LIVE_REFRESH_BURST_SECONDS=60
WEBTOON_LIVE_REFRESH_IDLE_SECONDS=600
WEBTOON_LIVE_DEMAND_WINDOW_SECONDS=120
WEBTOON_LIVE_DEMAND_THRESHOLD=4

# ── 서버 카탈로그 수집/DB 스냅샷 설정 ──
# 기본 off: 플랫폼 약관/robots/제휴 범위를 확인한 뒤 명시적으로 fixed로 켭니다.
# 서버는 scripts/crawl.mjs --json --no-file 결과를 DB catalog_snapshot에 저장합니다.
CATALOG_INGEST_MODE=off
CATALOG_INGEST_INTERVAL_SECONDS=1800
CATALOG_INGEST_TIMEOUT_MS=180000
CATALOG_INGEST_SCRIPT_MAX_OUTPUT_MB=12
CATALOG_CRAWL_SCRIPT=scripts/crawl.mjs
# /api/catalog/ingest/run 수동 실행 필수 토큰
CATALOG_INGEST_TRIGGER_TOKEN=

# ── 크롤러 호출량 제한 ──
# 미설정 시 가능한 범위를 수집하되, 운영에서는 플랫폼별 허용 범위에 맞춰 제한하세요.
WEBDEX_WEBTOON_CAP=
WEBDEX_SERIES_BONUS_CAP=
WEBDEX_KAKAO_WEBTOON_CAP=
WEBDEX_WEBTOON_FINISHED_PAGES=
WEBDEX_SERIES_PAGES_PER_GENRE=
WEBDEX_CRAWL_DELAY_MS=300

# ── Nest 백엔드 (새 API 서버) ──
NEST_API_URL=http://127.0.0.1:4001
NEST_API_PORT=4001

# ── 관리자 권한 ──
# 쉼표 구분 이메일 (없으면 users.role 값으로만 판단)
ADMIN_EMAILS=
