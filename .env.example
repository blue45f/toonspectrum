# ── DB (PostgreSQL) ──
# 미설정 시 로컬 docker Postgres(postgres://webdex:webdex@127.0.0.1:55432/webdex)로 폴백.
# 원격은 Neon 등 서버리스 Postgres 연결 문자열(sslmode=require). 스키마: pnpm exec drizzle-kit push.
# DB는 동적 데이터 전용(리뷰·커뮤니티·계정·창작 + ingest 실행 이력 수 KB) — 카탈로그는 파일 전용.
DATABASE_URL=
# pg 풀 슬림화(Neon 비용 가드): 유휴 연결을 빨리 닫아 Neon 컴퓨트가 autosuspend 되게 한다.
# WEBDEX_PG_POOL_MAX=3        # 최대 동시 연결(기본 3) — UGC 트래픽엔 충분
# WEBDEX_PG_IDLE_MS=10000     # 유휴 연결 종료(ms, 기본 10000) — 짧을수록 Neon이 빨리 잠든다

# ── 카탈로그 저장(파일 전용) ──
# 카탈로그 운영 소스는 gz 파일(기본 apps/api/data/catalog.json.gz). ingest가 원자적으로 갱신하고
# API는 부팅 로드 + mtime/size 스탯 폴링(CATALOG_REFRESH_POLL_SECONDS)으로 핫 리로드한다 — DB 전송 0.
# WEBDEX_CATALOG_FILE=        # 카탈로그 gz 경로 재정의(읽기/쓰기 공통, 별칭: WEBDEX_CATALOG_GZ)
# WEBDEX_CATALOG_FORCE_DB=    # (레거시) 1이면 DB catalog_snapshot 읽기/쓰기/DDL 경로로 복귀 —
#                             # Neon 전송 쿼터를 크게 소모하므로 롤백/검증 외에는 사용하지 않는다.
# 데이터 갱신(선택): 폴링 핫 리로드 주기(초, 0=off. 파일 모드=스탯 폴링, FORCE_DB=DB 폴링),
# 보존 스냅샷 개수(레거시 FORCE_DB 모드에서만 사용)
# CATALOG_REFRESH_POLL_SECONDS=60
# CATALOG_SNAPSHOT_RETENTION=5

# ── 실시간 라이브 랭킹 설정(보존된 어댑터용) ──
# 현재 프론트 정적 카탈로그와 Nest /api/ranking 기본 경로는 disableLive=true라 스냅샷 산식만 사용합니다.
# live.ts 어댑터를 별도 운영 경로에서 다시 연결할 때만 아래 값을 켜세요.
WEBTOON_LIVE_REFRESH_MODE=off
# WEBTOON_LIVE_TTL_SECONDS=120
# WEBTOON_LIVE_REFRESH_INTERVAL_SECONDS=120
# WEBTOON_LIVE_REFRESH_BURST_SECONDS=60
# WEBTOON_LIVE_REFRESH_IDLE_SECONDS=600
# adaptive 모드에서 최근 N초 내 요청이 임계치 이상이면 갱신 간격을 burst로 단축
# WEBTOON_LIVE_REFRESH_DEMAND_WINDOW_SECONDS=120
# WEBTOON_LIVE_REFRESH_DEMAND_THRESHOLD=4

# ── 서버 카탈로그 수집(ingest) 설정 ──
# 기본 off: 플랫폼 약관/robots/제휴 범위를 확인한 뒤 명시적으로 fixed로 켭니다.
# 서버는 scripts/crawl.mjs --json --no-file 결과를 검증해 catalog.json.gz 파일로 저장합니다
# (실행 이력만 DB catalog_ingest_run 에 기록 — 수 KB. WEBDEX_CATALOG_FORCE_DB=1 레거시 모드만 DB 스냅샷).
CATALOG_INGEST_MODE=off
CATALOG_INGEST_INTERVAL_SECONDS=1800
# 크롤 하드 타임아웃(기본 600000=10분, 범위 30000~1800000). 크롤러엔 timeout-30s 소프트 예산이 주입되고,
# 하드 타임아웃 도달 시 프로세스는 SIGKILL로 정리됩니다(좀비 방지).
CATALOG_INGEST_TIMEOUT_MS=600000
# stdout 최대 버퍼(MB, 기본 64). 기본 소스셋 크롤 JSON은 수십 MB라 너무 낮추면 maxBuffer 초과로 실패합니다.
CATALOG_INGEST_SCRIPT_MAX_OUTPUT_MB=64
CATALOG_CRAWL_SCRIPT=scripts/crawl.mjs
# 품질 게이트: 직전 스냅샷 대비 총건수가 이 비율 미만으로 급감하거나 주요 소스가 붕괴하면(force 아니면)
# 새 스냅샷 승격을 거부하고 run을 aborted로 기록 → 한 소스 차단 시 조용한 부분 회귀 방지 (0<r<=1)
CATALOG_INGEST_MIN_RETAIN_RATIO=0.6
# POST /api/catalog/ingest/run 수동 실행 토큰(x-catalog-ingest-token 헤더 또는 body token, 앞뒤 공백 무시).
# 미설정이면 토큰 인증 경로는 401로 거부되며, 관리자 세션(x-user-id) 경로로만 수동 실행할 수 있습니다.
# 같은 클라이언트의 호출은 분당 5회로 제한(429), 실행 중 재요청은 409로 거부됩니다.
CATALOG_INGEST_TRIGGER_TOKEN=

# ── 크롤러 호출량 제한 ──
# 미설정 시 가능한 범위를 수집하되, 운영에서는 플랫폼별 허용 범위에 맞춰 제한하세요.
# all은 레지스트리 전체를 뜻하지만, 실제 crawler 구현 소스만 실행되고 나머지는 status의 pending에 남습니다.
WEBDEX_SOURCE_IDS=all
WEBDEX_WEBTOON_CAP=
WEBDEX_WEBTOON_DETAIL_CAP=300
WEBDEX_SERIES_BONUS_CAP=
WEBDEX_KAKAO_WEBTOON_CAP=
WEBDEX_LEZHIN_CAP=
WEBDEX_WEBTOON_FINISHED_PAGES=
WEBDEX_SERIES_PAGES_PER_GENRE=
WEBDEX_CRAWL_DELAY_MS=300

# ── Nest 백엔드 (새 API 서버) ──
NEST_API_URL=http://127.0.0.1:4001
NEST_API_PORT=4001

# ── 관리자 권한 ──
# 쉼표 구분 이메일 (없으면 users.role 값으로만 판단)
ADMIN_EMAILS=

# ── 소셜 로그인 (Google · Kakao · Naver) ──
# Google: GIS(Google Identity Services) ID 토큰 흐름 — CLIENT ID 만 있으면 실연동(클라이언트 시크릿 불필요).
#   client id 가 없으면 데모 폴백(명확히 [데모] 표시)으로 동작합니다.
#   콘솔: https://console.cloud.google.com/apis/credentials → OAuth 2.0 클라이언트 ID(웹 애플리케이션)
#     - "승인된 JavaScript 원본"에 프론트 오리진(예: http://localhost:5173, https://<배포도메인>) 등록
#     - GIS 버튼은 ID 토큰을 발급하고 서버가 google-auth-library verifyIdToken 으로 검증합니다.
#   GOOGLE_OAUTH_CLIENT_SECRET 은 레거시 인가-코드(redirect) 폴백 경로에서만 쓰입니다(선택).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Kakao · Naver: 외부 앱키(REST API key / client id·secret) 발급이 필요해 현재 의도적으로 데모 고정입니다.
#   실연동하려면 아래 키를 채우고 lib/server/oauth.ts 의 DEMO_ONLY_PROVIDERS 에서 해당 제공자를 제거하세요.
#   - Kakao : https://developers.kakao.com → 내 애플리케이션 → 카카오 로그인 → REST API 키 / Redirect URI,
#             동의항목에서 닉네임/프로필이미지/이메일 활성화 (이메일 미동의 시 kakao_<id>@kakao.local 로 대체)
#   - Naver : https://developers.naver.com → 애플리케이션 등록 → Client ID/Secret, 네이버 로그인 콜백 URL
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
# OAuth 콜백을 받는 API 베이스 (기본 http://localhost:4001). 콘솔 등록 URI와 일치해야 함(레거시 code-flow 폴백).
OAUTH_REDIRECT_BASE_URL=http://localhost:4001
# 로그인 완료 후 사용자를 돌려보낼 프론트 베이스 (기본 http://localhost:5173)
WEB_APP_BASE_URL=http://localhost:5173
# OAuth state 서명 비밀키(미설정 시 프로세스마다 임의 생성 — 재시작 시 진행 중 로그인만 무효)
AUTH_STATE_SECRET=
# 세션 JWT(HS256) 서명 비밀키. 운영(NODE_ENV=production)에서는 필수 — 미설정 시 토큰 발급이 거부됩니다.
#   (미설정 시 AUTH_STATE_SECRET 을 폴백으로 사용; 개발 환경에서만 약한 기본 비밀 허용)
AUTH_SESSION_SECRET=
