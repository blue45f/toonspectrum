{
  "name": "toonspectrum",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "vite preview --host 0.0.0.0",
    "dev:api": "pnpm --filter @webtoon-nest/api dev",
    "dev:all": "pnpm -r --parallel --include-workspace-root dev",
    "crawl": "node scripts/crawl.mjs --json --no-file",
    "ingest": "node scripts/ingest.mjs",
    "catalog:gen": "tsx scripts/build-static-catalog.ts",
    "catalog:update": "node scripts/crawl.mjs --json --no-file > /tmp/toonspectrum-catalog.json && gzip -9 -c /tmp/toonspectrum-catalog.json > apps/api/data/catalog.json.gz && pnpm catalog:gen",
    "predev": "pnpm catalog:gen",
    "prebuild": "pnpm catalog:gen",
    "build:all": "pnpm -r run build",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json && pnpm --filter @webtoon-nest/api run typecheck",
    "test": "vitest run",
    "validate:architecture": "node scripts/validate-architecture.mjs",
    "ci": "pnpm run validate:architecture && pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run build:all",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "verify": "pnpm run ci",
    "verify:push": "pnpm run verify",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx lib/db/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@pixiv/three-vrm": "^3.5.3",
    "@radix-ui/react-select": "^2.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "google-auth-library": "^10.7.0",
    "konva": "^10.3.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-konva": "^19.2.4",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@heejun/eslint-config": "^4.0.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  }
}
