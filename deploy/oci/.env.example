# WEBDEX OCI 백엔드 .env — `cp .env.example .env` 후 채우기. 절대 커밋하지 말 것.
# 비밀값은 현재 Vercel 환경변수 / 레포 루트 .env.local 에서 그대로 복사하면 된다.

# ── 인프라 ────────────────────────────────────────────────
DOMAIN=api.example.com            # 이 API 서버의 공개 도메인(DNS A 레코드 → VM 공인 IP)
ACME_EMAIL=you@example.com        # Let's Encrypt 알림 메일
POSTGRES_USER=webdex
POSTGRES_PASSWORD=                 # 강력한 랜덤 문자열(예: openssl rand -base64 24)
POSTGRES_DB=webdex

# ── 앱(현재 .env.local / Vercel 값 복사) ──────────────────
AUTH_SECRET=                       # 세션 서명 시크릿
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
ADMIN_EMAILS=                      # 콤마 구분 관리자 이메일

# ── Postgres 튜닝(선택, 인스턴스 리사이즈 시 상향) ─────────
# 기본값은 ≈6GB VM 기준. 4 OCPU/24GB로 키우면 예: PG_SHARED_BUFFERS=6GB PG_EFFECTIVE_CACHE=16GB
# PG_SHARED_BUFFERS=1GB
# PG_EFFECTIVE_CACHE=3GB
# PG_WORK_MEM=16MB
# PG_MAX_CONN=50

# ── 크롤 cron(crawl-update.sh, 선택) ──────────────────────
NAVER_COOKIE=                      # 19+ 표지 인증 크롤용(성인인증된 세션). 미설정 시 익명 크롤
DISCORD_WEBHOOK_URL=               # 신작/영상화 다이제스트 + 검증 실패 알림
VERCEL_DEPLOY_HOOK_URL=            # 검증 통과 시 Vercel 재배포 트리거(정적 카탈로그 반영)
WEBDEX_SITE_URL=https://webtoon-index.vercel.app
