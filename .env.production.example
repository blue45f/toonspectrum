# ── WEBDEX 프로덕션 환경변수 템플릿 ──
# 프론트(Vercel)와 API(Render/Railway 등 상시구동)를 분리 배포한다.
# 프론트는 상대경로 /api 로 호출 → Vercel rewrite(vercel.json)가 API 호스트로 프록시(단일 오리진, CORS 불필요).
# 아래 값은 대부분 "API 호스트"에 설정한다(프론트는 빌드 타임 VITE_* 만 필요, 현재는 불필요).

# ===== API 호스트(Render 등)에 설정 =====

# [필수] Neon PostgreSQL 연결 문자열 (sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/webdex?sslmode=require

# 포트 — Render/Railway/Fly 는 PORT를 자동 주입(미설정 시 NEST_API_PORT→4001).
# PORT=10000

# OAuth state 서명 키(미설정 시 프로세스마다 임의 생성 → 재기동 중 진행 로그인만 무효). 상용은 고정 권장.
AUTH_STATE_SECRET=

# 소셜 로그인 실연동(둘 다 채워야 해당 제공자 실 OAuth, 아니면 [데모] 폴백)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 카카오: REST API 키 + (선택)client secret. KAKAO_OAUTH_CLIENT_ID / KAKAO_OAUTH_CLIENT_SECRET 이름도 폴백 허용.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# OAuth 콜백/복귀 베이스 — 단일 오리진 유지를 위해 둘 다 "프론트(Vercel) 공개 도메인"으로 설정.
#   콜백 등록 URL: <WEB_APP_BASE_URL>/api/auth/oauth/{google,kakao}/callback
OAUTH_REDIRECT_BASE_URL=https://your-app.vercel.app
WEB_APP_BASE_URL=https://your-app.vercel.app

# 관리자 이메일 화이트리스트(선택, 쉼표 구분). 없으면 users.role 로만 판단.
ADMIN_EMAILS=

# 데이터 갱신: 카탈로그는 Neon catalog_snapshot 에서 부팅 시 로드된다.
# off=자동 크롤 안 함(권장, 갱신은 GitHub cron이 트리거). fixed=API가 주기 크롤.
CATALOG_INGEST_MODE=off
# 수동/cron 크롤 트리거 토큰 — GitHub Actions(refresh-data.yml) 시크릿과 동일 값.
CATALOG_INGEST_TRIGGER_TOKEN=
# DB 스냅샷 변경 핫리로드 폴링(초). 0=off.
CATALOG_REFRESH_POLL_SECONDS=60

TZ=Asia/Seoul

# ===== 프론트(Vercel)에 설정(선택) =====
# 기본은 vercel.json 의 /api rewrite 프록시를 쓰므로 불필요.
# 프록시 대신 API를 직접 호출하려면(이 경우 API에 CORS 설정 필요) 빌드 타임에:
# VITE_API_BASE=https://webdex-api.onrender.com
